{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/aviso-privacidad",
      "destination": "/aviso-privacidad.html"
    },
    {
      "source": "/terminos",
      "destination": "/terminos.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
